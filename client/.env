# React App Environment Variables
# API Configuration - Update these based on your server setup
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# GitHub OAuth Configuration
# This should be the SAME as GITHUB_CLIENT_ID in server/.env
# Get it from: https://github.com/settings/developers > OAuth Apps > Your App > Client ID
REACT_APP_GITHUB_CLIENT_ID=Ov23li8FKnEzyEFFtfGJ
